{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto py-12 px-4">
    <header class="bg-gray-800 text-white p-6 rounded-lg mb-8">
        <h1 class="text-3xl font-bold">Admin Dashboard</h1>
        <p class="mt-2">Welcome, <strong>{{ user.email }}</strong></p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <a href="{{ path('admin_article_index') }}" class="bg-blue-500 text-white p-8 rounded-lg text-center hover:bg-blue-600 transition no-underline">
            <h2 class="text-5xl mb-3">📝</h2>
            <h3 class="text-xl font-semibold">Articles</h3>
            <p class="mt-2 opacity-90">Manage articles</p>
        </a>

        <div class="bg-green-500 text-white p-8 rounded-lg text-center">
            <h2 class="text-5xl mb-3">👤</h2>
            <h3 class="text-xl font-semibold">Users</h3>
            <p class="mt-2 opacity-90">Manage users</p>
        </div>

        <div class="bg-orange-500 text-white p-8 rounded-lg text-center">
            <h2 class="text-5xl mb-3">⚙️</h2>
            <h3 class="text-xl font-semibold">Settings</h3>
            <p class="mt-2 opacity-90">System configuration</p>
        </div>

        <div class="bg-red-500 text-white p-8 rounded-lg text-center">
            <h2 class="text-5xl mb-3">📊</h2>
            <h3 class="text-xl font-semibold">Reports</h3>
            <p class="mt-2 opacity-90">View analytics</p>
        </div>
    </div>

    {# Health Check Section - Using Stimulus Controller #}
    <div class="bg-white shadow-lg rounded-lg p-6 mb-8" data-controller="health-check">
        <h3 class="text-xl font-semibold mb-4 flex items-center">
            <span class="text-2xl mr-2">🏥</span>
            API Health Check
        </h3>
        <p class="text-gray-600 mb-4">Test the API endpoint to ensure the system is running properly</p>

        <button
            data-health-check-target="button"
            data-action="click->health-check#check"
            class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg transition disabled:opacity-50 disabled:cursor-not-allowed"
        >
            Check API Health
        </button>

        <div data-health-check-target="result" class="mt-4"></div>
    </div>

    <div class="bg-gray-100 p-6 rounded-lg border-l-4 border-blue-500">
        <h3 class="text-lg font-semibold mb-3">Your Roles:</h3>
        <ul class="space-y-1">
            {% for role in user.roles %}
                <li><code class="bg-gray-200 px-2 py-1 rounded">{{ role }}</code></li>
            {% endfor %}
        </ul>
    </div>

    <div class="mt-8 text-center space-x-4">
        <a href="{{ path('app_home') }}" class="inline-block px-6 py-3 bg-gray-500 hover:bg-gray-600 text-white rounded-lg transition no-underline">
            ← Back to Home
        </a>
        <a href="{{ path('app_logout') }}" class="inline-block px-6 py-3 bg-red-500 hover:bg-red-600 text-white rounded-lg transition no-underline">
            Logout
        </a>
    </div>
</div>
{% endblock %}
